option_settings:
    aws:elasticbeanstalk:container:python:
        WSGIPath: file_management_sys.wsgi:application
    aws:elasticbeanstalk:application:environment:
        DJANGO_SETTINGS_MODULE: file_management_sys.settings.prod


container_commands:
    01_migrate:
        command: "python manage.py migrate --noinput"
        leader_only: true
    02_collectstatic:
        command: "python manage.py collectstatic --noinput"
        leader_only: true

    
create `Procfile`:

web: gunicorn file_management_sys.wsgi --bind 0.0.0.0:$PORT --workers 3